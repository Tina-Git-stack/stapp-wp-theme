{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1600px"
        },
        "color": {
            "custom": true,
            "customDuotone": true,
            "customGradient": true,
            "defaultGradients": true,
            "defaultPalette": false,
            "palette": [
                {
                    "slug": "primary",
                    "color": "#007aff",
                    "name": "Primär (Blau)"
                },
                {
                    "slug": "secondary",
                    "color": "#4a90e2",
                    "name": "Sekundär (Hellblau)"
                },
                {
                    "slug": "accent-cyan",
                    "color": "#66EFE2",
                    "name": "Akzent Türkis"
                },
                {
                    "slug": "accent-blue",
                    "color": "#0A95FE",
                    "name": "Akzent Blau"
                },
                {
                    "slug": "dark",
                    "color": "#1a1a1a",
                    "name": "Dunkel"
                },
                {
                    "slug": "darker",
                    "color": "#0f0f0f",
                    "name": "Sehr dunkel"
                },
                {
                    "slug": "white",
                    "color": "#ffffff",
                    "name": "Weiß"
                },
                {
                    "slug": "text-light",
                    "color": "rgba(255,255,255,0.85)",
                    "name": "Text hell"
                },
                {
                    "slug": "text-muted",
                    "color": "rgba(255,255,255,0.6)",
                    "name": "Text gedämpft"
                }
            ]
        },
        "typography": {
            "customFontSize": true,
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "14px",
                    "name": "Klein"
                },
                {
                    "slug": "normal",
                    "size": "16px",
                    "name": "Normal"
                },
                {
                    "slug": "medium",
                    "size": "20px",
                    "name": "Mittel"
                },
                {
                    "slug": "large",
                    "size": "28px",
                    "name": "Groß"
                },
                {
                    "slug": "x-large",
                    "size": "36px",
                    "name": "Sehr groß"
                },
                {
                    "slug": "xx-large",
                    "size": "3rem",
                    "name": "XXL"
                },
                {
                    "slug": "hero",
                    "size": "clamp(2.5rem, 6vw, 4.5rem)",
                    "name": "Hero"
                }
            ],
            "lineHeight": true
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true,
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "spacingSizes": [
                { "slug": "10", "size": "2%", "name": "XS (2%)" },
                { "slug": "20", "size": "4%", "name": "S (4%)" },
                { "slug": "30", "size": "6%", "name": "M (6%)" },
                { "slug": "40", "size": "8%", "name": "L (8%)" },
                { "slug": "50", "size": "12%", "name": "XL (12%)" },
                { "slug": "60", "size": "16%", "name": "XXL (16%)" },
                { "slug": "70", "size": "24%", "name": "XXXL (24%)" }
            ]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        }
    },
    "styles": {
        "color": {
            "background": "#1a1a1a",
            "text": "rgba(255, 255, 255, 0.85)"
        },
        "typography": {
            "fontFamily": "-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif",
            "fontSize": "var(--wp--preset--font-size--normal)",
            "lineHeight": "1.6"
        },
        "spacing": {
            "padding": {
                "top": "0",
                "right": "0",
                "bottom": "0",
                "left": "0"
            }
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                ":hover": {
                    "typography": {
                        "textDecoration": "underline"
                    }
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "2.5rem",
                    "lineHeight": "1.2"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "2rem",
                    "lineHeight": "1.3"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "1.75rem",
                    "lineHeight": "1.4"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "1.5rem",
                    "lineHeight": "1.4"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "1.25rem",
                    "lineHeight": "1.5"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "1rem",
                    "lineHeight": "1.5"
                }
            }
        },
        "blocks": {
            "core/button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--white)"
                },
                "border": {
                    "radius": "4px"
                }
            }
        }
    },
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}
